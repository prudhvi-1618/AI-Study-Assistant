# ============================================================
# AI Study Assistant - Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your actual values
# Note: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser

# ============================================================
# API CONFIGURATION
# ============================================================
# Backend API base URL
# Development: http://localhost:3001/api/v1
# Production: https://your-backend-domain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ============================================================
# APPLICATION ENVIRONMENT
# ============================================================
# Set to: development, staging, or production
NEXT_PUBLIC_ENV=development

# ============================================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================================
# Uncomment and add your analytics IDs if needed
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ============================================================
# OPTIONAL: FEATURE FLAGS
# ============================================================
# Enable/disable experimental features
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# ============================================================
# NOTES
# ============================================================
# - Only variables prefixed with NEXT_PUBLIC_ are accessible in the browser
# - Private environment variables can be used in server-side code (API routes, getServerSideProps, etc.)
# - Never expose sensitive API keys using NEXT_PUBLIC_ prefix
# - Update NEXT_PUBLIC_API_URL to match your backend deployment
# - For production, use HTTPS URLs
