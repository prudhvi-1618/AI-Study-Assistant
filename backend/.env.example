# ============================================================
# AI Study Assistant - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# DATABASE - MySQL
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=study_assistant

# ============================================================
# REDIS CACHE & SESSION STORAGE
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                        # Leave empty if no password
REDIS_URL=                             # Optional: connection string for managed Redis

# ============================================================
# QDRANT VECTOR DATABASE
# ============================================================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=document_embeddings

# ============================================================
# AUTHENTICATION - JWT
# ============================================================
# Generate strong random strings (32+ characters)
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=your_32_char_access_token_secret_key_here_min_32_chars
REFRESH_TOKEN_SECRET=your_32_char_refresh_token_secret_key_here_min_32_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ============================================================
# PASSWORD SECURITY
# ============================================================
# Number of salt rounds for bcrypt hashing (higher = more secure but slower)
BCRYPT_ROUNDS=12

# ============================================================
# FILE UPLOAD CONFIGURATION
# ============================================================
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,txt,pptx,md

# ============================================================
# AI MODELS & EMBEDDINGS
# ============================================================
# Embedding model for RAG
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_BATCH_SIZE=100

# Model for generating flashcards
FLASHCARD_GENERATION_MODEL=gemini-3.5-flash

# Model for generating quizzes
QUIZ_GENERATION_MODEL=gemini-3.5-flash

# Model for chat responses
CHAT_MODEL=gemini-3.5-flash

# Model for summarizing notes
SUMMARY_MODEL=gemini-3.5-flash

# ============================================================
# CHAT CONFIGURATION
# ============================================================
# Maximum chat history messages to keep in memory
CHAT_MAX_HISTORY_MESSAGES=20

# Threshold before summarizing chat history
CHAT_MEMORY_SUMMARY_THRESHOLD=10

# TTL for chat memory in Redis (86400 = 24 hours)
REDIS_CHAT_MEMORY_TTL=86400

# TTL for summary cache (3600 = 1 hour)
REDIS_SUMMARY_CACHE_TTL=3600

# ============================================================
# RAG CONFIGURATION
# ============================================================
# Number of context chunks to retrieve for RAG
MAX_CONTEXT_CHUNKS=5

# ============================================================
# TASK PROCESSING - BullMQ
# ============================================================
# Number of concurrent jobs to process
BULLMQ_CONCURRENCY=3

# ============================================================
# STREAMING CONFIGURATION
# ============================================================
# Enable token-by-token streaming for responses
STREAMING_ENABLED=true

# ============================================================
# GENERAL CACHE
# ============================================================
# Default TTL for cached items in seconds (3600 = 1 hour)
REDIS_CACHE_TTL_SECONDS=3600

# ============================================================
# FEATURE LIMITS
# ============================================================
# Maximum flashcards per generated deck
MAX_FLASHCARDS_PER_DECK=50

# Maximum quiz questions per generation
MAX_QUIZ_QUESTIONS=30

# ============================================================
# LLM API KEYS
# ============================================================

# Google Gemini API (PRIMARY)
# Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API (ALTERNATIVE/BACKUP)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# NOTES
# ============================================================
# - At least one of GEMINI_API_KEY or OPENAI_API_KEY must be set
# - Generate JWT secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# - For production, use strong, unique values for all secrets
# - Never commit .env file to version control
# - Use environment-specific .env files for different deployments
